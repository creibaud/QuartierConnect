{
    "name": "api",
    "version": "1.0.0",
    "description": "",
    "author": "",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write . && pnpm lint",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main.js",
        "lint": "eslint . --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "db:generate": "dotenv -- drizzle-kit generate",
        "db:migrate": "dotenv -- drizzle-kit migrate",
        "db:studio": "dotenv -- drizzle-kit studio",
        "db:push": "dotenv -- drizzle-kit push",
        "db:drop": "dotenv -- drizzle-kit drop",
        "db:seed": "dotenv -- ts-node --transpile-only -r tsconfig-paths/register scripts/seed.ts",
        "db:seed:reset": "dotenv -- ts-node --transpile-only -r tsconfig-paths/register scripts/reset-seed.ts --force",
        "db:neo4j:sync-users": "dotenv -- ts-node --transpile-only -r tsconfig-paths/register scripts/sync-neo4j-users.ts",
        "outbox:process": "dotenv -- ts-node --transpile-only -r tsconfig-paths/register scripts/process-outbox.ts",
        "outbox:requeue": "dotenv -- ts-node --transpile-only -r tsconfig-paths/register scripts/requeue-dead-letter.ts"
    },
    "dependencies": {
        "@nestjs-modules/mailer": "^2.3.0",
        "@nestjs/common": "^11.1.17",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.17",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.17",
        "@nestjs/platform-socket.io": "^11.1.17",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/websockets": "^11.1.17",
        "@scalar/nestjs-api-reference": "^1.0.0",
        "bcryptjs": "^3.0.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.3.1",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.1",
        "mongodb": "^6.21.0",
        "neo4j-driver": "^6.0.1",
        "nodemailer": "^8.0.3",
        "otplib": "^12.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pdf-lib": "^1.17.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "socket.io": "^4.8.3",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/schematics": "^11.0.9",
        "@nestjs/testing": "^11.1.17",
        "@types/bcryptjs": "^3.0.0",
        "@types/cookie-parser": "^1.4.8",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^22.19.15",
        "@types/nodemailer": "^7.0.11",
        "@types/passport-jwt": "^4.0.1",
        "@types/pg": "^8.20.0",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^11.0.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^16.5.0",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "transformIgnorePatterns": [
            "/node_modules/(?!uuid)"
        ],
        "moduleNameMapper": {
            "^src/(.*)$": "<rootDir>/$1"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s",
            "!**/*.module.ts",
            "!**/main.ts",
            "!**/seed.ts",
            "!**/database/drizzle/drizzle.provider.ts",
            "!**/database/drizzle/schema/**",
            "!**/database/drizzle/migrations/**"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}

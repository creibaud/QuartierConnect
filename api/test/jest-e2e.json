{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": ".e2e-spec.ts$",
    "moduleNameMapper": {
        "^src/(.*)$": "<rootDir>/../src/$1",
        "^uuid$": "<rootDir>/uuid-cjs.js"
    },
    "transform": {
        "^.+\\.(t|j)s$": "ts-jest"
    }
}

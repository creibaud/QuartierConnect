# Copie ce fichier vers .env (racine du repo), puis remplace TOUTES les valeurs
# CHANGE_ME_* par de vraies valeurs. Génère un secret / mot de passe avec :
#   openssl rand -base64 24
# IMPORTANT : pas d'espaces ni de < > dans les mots de passe. Ces caractères
# cassent la commande shell du healthcheck mongo (docker-compose) et font
# échouer le démarrage. Garde chaque mot de passe synchronisé entre sa variable
# et l'URI qui l'embarque (MONGO_ROOT_PASSWORD <-> MONGO_URI,
# POSTGRES_PASSWORD <-> POSTGRES_URL, NEO4J_AUTH <-> NEO4J_PASSWORD).

# NestJS
PORT=5000
JWT_SECRET=CHANGE_ME_openssl_rand_base64_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# CORS : origines autorisées (virgule-séparées). Défaut local : localhost:3000,3001,5000
# CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=CHANGE_ME_mongo_password
MONGO_URI=mongodb://root:CHANGE_ME_mongo_password@localhost:27017/quartierconnect?authSource=admin

# PostgreSQL (Étape 3)
POSTGRES_USER=qc
POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=quartierconnect
POSTGRES_URL=postgresql://qc:CHANGE_ME_postgres_password@localhost:5432/quartierconnect

# Neo4j (Étape 4)
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/CHANGE_ME_neo4j_password
# The API uses NEO4J_USER/NEO4J_PASSWORD (separate vars). Keep them in sync with NEO4J_AUTH.
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# DSL — pythonia spawns this binary, which must have `ply` installed (use the dsl venv).
PYTHON_BIN=./dsl/.venv/bin/python
DSL_PATH=./dsl

# Demo TOTP secret (seed-demo.ts) — oathtool -b --totp JBSWY3DPEHPK3PXP
DEMO_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Login rate limit (attempts per 15min per IP). Default 5 prod. Set higher for dev/test.
LOGIN_RATE_LIMIT=100

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.quartierconnect.desktopapp.controller.DashboardController"
            styleClass="dashboard-root">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240" spacing="0">

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="4">
                <HBox fx:id="brandLogoContainer" alignment="CENTER_LEFT" spacing="10">
                    <javafx.scene.shape.Rectangle width="24" height="24" styleClass="brand-icon" arcWidth="6" arcHeight="6"/>
                    <Label text="QuartierConnect" styleClass="brand-name"/>
                </HBox>
                <Label text="Admin Portal" styleClass="sidebar-brand-sub"/>
            </VBox>

            <Separator styleClass="sidebar-sep"/>

            <!-- Navigation -->
            <VBox styleClass="nav-section" spacing="2" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" styleClass="nav-section-label"/>

                <VBox fx:id="navOverview" styleClass="nav-item nav-item-active" onMouseClicked="#onOverviewClick">
                    <Label text="⊞  Overview" styleClass="nav-item-text"/>
                </VBox>

                <VBox fx:id="navIncidents" styleClass="nav-item" onMouseClicked="#onIncidentsClick">
                    <Label text="⚠  Incidents" styleClass="nav-item-text"/>
                </VBox>

                <VBox fx:id="navEvents" styleClass="nav-item" onMouseClicked="#onEventsClick">
                    <Label text="◑  Events" styleClass="nav-item-text"/>
                </VBox>

                <VBox fx:id="navUsers" styleClass="nav-item" onMouseClicked="#onUsersClick">
                    <Label text="◉  Users" styleClass="nav-item-text"/>
                </VBox>
            </VBox>

            <!-- User info + logout -->
            <Separator styleClass="sidebar-sep"/>
            <VBox styleClass="sidebar-user" spacing="8">
                <Label fx:id="userEmailLabel" styleClass="user-email" wrapText="true"/>
                <Label fx:id="userRoleLabel" styleClass="user-role-badge"/>
                <Button text="Sign out" styleClass="btn-ghost-sm" maxWidth="Infinity" onAction="#onLogout"/>
            </VBox>

        </VBox>
    </left>

    <!-- Main content -->
    <center>
        <VBox styleClass="main-content" spacing="0">

            <!-- Top bar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="0">
                <Label text="Dashboard" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="QuartierConnect Admin" styleClass="topbar-hint"/>
            </HBox>

            <!-- Content area (swapped on navigation) -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area">

                <!-- Overview section (default) -->
                <VBox fx:id="overviewSection" spacing="24" styleClass="section-pane">
                    <Label text="Overview" styleClass="section-title"/>

                    <!-- Stat cards -->
                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="ACTIVE INCIDENTS" styleClass="stat-label"/>
                            <Label text="—" styleClass="stat-value"/>
                            <Label text="Open reports requiring attention" styleClass="stat-sub"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="UPCOMING EVENTS" styleClass="stat-label"/>
                            <Label text="—" styleClass="stat-value"/>
                            <Label text="Scheduled community events" styleClass="stat-sub"/>
                        </VBox>
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <Label text="REGISTERED USERS" styleClass="stat-label"/>
                            <Label text="—" styleClass="stat-value"/>
                            <Label text="Active residents in system" styleClass="stat-sub"/>
                        </VBox>
                    </HBox>

                    <!-- Quick info -->
                    <VBox styleClass="info-card" spacing="12">
                        <Label text="System Status" styleClass="card-title"/>
                        <Separator/>
                        <Label text="Connected to QuartierConnect API via SSO. Use the navigation on the left to manage your community." styleClass="info-text" wrapText="true"/>
                    </VBox>
                </VBox>

                <!-- Incidents placeholder -->
                <Label fx:id="incidentsSection"
                       text="Incidents management — coming soon"
                       styleClass="placeholder-label"
                       visible="false" managed="false"/>

                <!-- Events placeholder -->
                <Label fx:id="eventsSection"
                       text="Events management — coming soon"
                       styleClass="placeholder-label"
                       visible="false" managed="false"/>

                <!-- Users placeholder -->
                <Label fx:id="usersSection"
                       text="Users management — coming soon"
                       styleClass="placeholder-label"
                       visible="false" managed="false"/>

            </StackPane>
        </VBox>
    </center>

</BorderPane>

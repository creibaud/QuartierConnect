<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.quartierconnect.desktopapp.controller.LoginController"
      styleClass="root-pane"
      alignment="CENTER"
      spacing="0">

    <VBox styleClass="login-card" spacing="0" maxWidth="400" maxHeight="560">

        <!-- Header -->
        <VBox styleClass="login-header" spacing="6">
            <HBox fx:id="loginBrandLogoContainer" alignment="CENTER_LEFT" spacing="10">
                <javafx.scene.shape.Rectangle width="28" height="28" styleClass="brand-icon" arcWidth="8" arcHeight="8"/>
                <Label text="QuartierConnect" styleClass="brand-name"/>
            </HBox>
            <Label text="Admin Portal" styleClass="login-subtitle"/>
        </VBox>

        <Region styleClass="login-divider"/>

        <!-- Form -->
        <VBox styleClass="login-body" spacing="20">

            <VBox spacing="6">
                <Label text="Email address" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="admin@example.com"
                           styleClass="input-field"
                           onAction="#onLogin"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                              promptText="••••••••"
                              styleClass="input-field"
                              onAction="#onLogin"/>
            </VBox>

            <!-- TOTP (shown after 2FA prompt) -->
            <VBox fx:id="totpSection" spacing="6">
                <Label text="Authenticator code" styleClass="field-label"/>
                <TextField fx:id="totpField"
                           promptText="6-digit code"
                           styleClass="input-field"
                           onAction="#onLogin"/>
            </VBox>

            <!-- Error message -->
            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <!-- Submit -->
            <VBox spacing="10" alignment="CENTER">
                <Button fx:id="loginButton"
                        text="Sign in to Admin Portal"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        onAction="#onLogin"/>

                <Button fx:id="ssoButton"
                        text="Login via Web"
                        styleClass="btn-secondary"
                        maxWidth="Infinity"
                        onAction="#onSSO"/>

                <HBox alignment="CENTER" spacing="8">
                    <ProgressIndicator fx:id="spinner" prefWidth="18" prefHeight="18" styleClass="spinner"/>
                    <Label text="Authenticating…" styleClass="loading-label"/>
                </HBox>
            </VBox>

        </VBox>

        <!-- Footer note -->
        <VBox styleClass="login-footer" alignment="CENTER">
            <Label text="This portal requires administrator credentials." styleClass="footer-note"/>
        </VBox>

    </VBox>

</VBox>

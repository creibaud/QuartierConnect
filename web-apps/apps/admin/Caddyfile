:3001 {
	encode gzip

	@static path_regexp \.(js|css|woff2?|ttf|svg|png|ico|woff)$
	header @static Cache-Control "public, max-age=31536000, immutable"

	handle_path /api/* {
		reverse_proxy api:5000
	}

	handle {
		root * /srv
		# Strip /admin prefix so file_server finds assets at /srv/assets/...
		@hasAdminPrefix path_regexp ^/admin/(.*)$
		rewrite @hasAdminPrefix /{http.regexp.1}
		try_files {path} /index.html
		file_server
	}
}

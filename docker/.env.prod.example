# Copier vers .env sur le VPS et remplir toutes les valeurs <generate>

# Domaine et HTTPS
DOMAIN=quartierconnect.fr
ACME_EMAIL=admin@quartierconnect.fr

# NestJS
PORT=5000
NODE_ENV=production
# openssl rand -base64 48
JWT_SECRET=<generate-min-48-chars>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=https://quartierconnect.fr
LOGIN_RATE_LIMIT=5

# MongoDB
MONGO_ROOT_USER=root
# openssl rand -base64 32 | tr -d '/+='
MONGO_ROOT_PASSWORD=<generate>
MONGO_URI=mongodb://root:<password>@mongo:27017/quartierconnect?authSource=admin

# PostgreSQL
POSTGRES_USER=qc
POSTGRES_PASSWORD=<generate>
POSTGRES_DB=quartierconnect
POSTGRES_URL=postgresql://qc:<password>@postgres:5432/quartierconnect

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<generate>
NEO4J_AUTH=neo4j/<same-as-NEO4J_PASSWORD>

# Démo
DEMO_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Backups S3 (Scaleway / Backblaze)
BACKUP_BUCKET=quartierconnect-backups
BACKUP_S3_ENDPOINT=s3.fr-par.scw.cloud
BACKUP_S3_ACCESS_KEY=<generate>
BACKUP_S3_SECRET_KEY=<generate>
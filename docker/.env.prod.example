# ─── Environnement PRODUCTION — QuartierConnect ──────────────────────────────
# Copier à la racine du dépôt en .env, puis `chmod 600 .env` et remplir CHAQUE
# secret :  cp docker/.env.prod.example .env
# Générer un secret :  openssl rand -base64 32 | tr -d '/+='

# NestJS
PORT=5000
JWT_SECRET=<openssl rand -base64 48 | tr -d '/+='>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Production : uniquement l'origine HTTPS publique.
CORS_ORIGINS=https://quartierconnect.fr

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=<mot de passe fort>
MONGO_URI=mongodb://root:<password>@mongo:27017/quartierconnect?authSource=admin

# PostgreSQL
POSTGRES_USER=qc
POSTGRES_PASSWORD=<mot de passe fort>
POSTGRES_DB=quartierconnect
POSTGRES_URL=postgresql://qc:<password>@postgres:5432/quartierconnect

# Neo4j (garder NEO4J_AUTH et NEO4J_USER/PASSWORD synchronisés)
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/<mot de passe fort>
NEO4J_USER=neo4j
NEO4J_PASSWORD=<mot de passe fort>

# DSL (dans le conteneur api)
PYTHON_BIN=python3
DSL_PATH=/app/dsl

# Secret TOTP démo (utile seulement si on seed les comptes démo en prod)
DEMO_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Rate limit production (tentatives de login / 15 min / IP)
LOGIN_RATE_LIMIT=5

# ─── Backups off-site (optionnel — utilisé par scripts/backup-all.sh) ────────
# Compatible S3 : AWS S3, Scaleway, Backblaze B2…
BACKUP_BUCKET=
BACKUP_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
BACKUP_RETENTION_DAYS=7

# ─── Notifications ops (optionnel) ───────────────────────────────────────────
# Webhook Discord pour les alertes deploy + backup
DISCORD_WEBHOOK=
# Domaine public utilisé par smoke-test.sh / deploy-vps.sh (sans https://)
PROD_DOMAIN=quartierconnect.fr
